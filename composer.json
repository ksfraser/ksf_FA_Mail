{
    "name": "ksfraser/ksf-fa-mail",
    "description": "SMTP mail module for FrontAccounting using PHPMailer",
    "type": "fa-module",
    "license": "GPL-3.0",
    "require": {
        "php": ">=7.4",
        "phpmailer/phpmailer": "^6.9",
        "ksfraser/traits": "*",
        "ksfraser/exceptions": "*",
        "ksfraser/genericinterface": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\": "src/Ksfraser/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "platform": {
            "php": "7.4.33"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../Traits"
        }
    ]
}
